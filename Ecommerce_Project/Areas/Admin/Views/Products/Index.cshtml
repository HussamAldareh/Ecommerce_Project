@using System.Text.Encodings.Web

@model IEnumerable<Ecommerce_Project.Models.Product>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Product Catalogue";
}



<div>

    <div class="page-header d-flex justify-content-between align-items-center mb-4">
        <h5>
            <i class="bi bi-box-seam-fill me-2" style="color:var(--gold)"></i>
            Manage Products
        </h5>
        <a asp-area="Admin"
           asp-controller="Products"
           asp-action="Create"
           class="btn-lx-primary">
            <i class="bi bi-plus-lg"></i>
            Add New Product
        </a>


        


    </div>

    <div class="lx-card">

        <div class="filter-bar mb-3">
            <div class="search-wrap">
                <i class="bi bi-search"></i>

                <input type="text"
                       id="productSearch"
                       onkeyup="filterTbl('productTable', this.value)"
                       placeholder="Search products..." />
            </div>
        </div>

        <div class="table-wrap">

            <table class="lx-table" id="productTable">

                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Category</th>
                        <th>Price</th>
                        <th>Stock</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>
                                <div class="td-product d-flex align-items-center gap-2">

                                    <div class="td-thumb">
                                        <img src="@(item.ProductImages?.FirstOrDefault()?.ImageUrl ?? "/images/no-image.png")"
                                             width="55"
                                             height="55"
                                             style="object-fit:cover;border-radius:10px;" />
                                    </div>

                                    <div class="td-name">
                                        @item.Name
                                    </div>

                                </div>
                            </td>

                            <td>
                                <span class="lx-badge b-dark">
                                    @item.Category?.Name
                                </span>
                            </td>

                            <td>
                                <strong>@item.Price.ToString("C")</strong>
                            </td>

                            <td>
                                <span>@item.StockQuantity</span>
                            </td>

                            <td>

                                <div class="d-flex gap-2 align-items-center">

                                    <!-- EDIT -->
                                    <a asp-area="Admin"
                                       asp-controller="Products"
                                       asp-action="Edit"
                                       asp-route-id="@item.Id"
                                       class="btn-icon edit"
                                       title="Edit">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>

                                    <!-- DETAILS -->
                                    <a asp-area="Admin"
                                       asp-controller="Products"
                                       asp-action="Details"
                                       asp-route-id="@item.Id"
                                       class="btn-icon view"
                                       title="View"  >
                                        <i class="bi bi-eye-fill"></i>
                                    </a>
                                    <!-- DELETE -->
                                    <button type="button"
                                            class="btn-icon del"
                                            onclick="confirmProductDelete(@item.Id, '@Html.Raw(JavaScriptEncoder.Default.Encode(item.Name))')">

                                        <i class="bi bi-trash3-fill"></i>
                                    </button>

                                    <!-- HIDDEN FORM -->
                                    <form id="delete-form-@item.Id"
                                          asp-area="Admin"
                                          asp-controller="Products"
                                          asp-action="Delete"
                                          asp-route-id="@item.Id"
                                          method="post"
                                          style="display:none;">

                                        @Html.AntiForgeryToken()
                                    </form>

                                </div>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>

@section Scripts {

    <script>

        console.log("PRODUCT PAGE LOADED");

        function confirmProductDelete(id, name) {

            Swal.fire({
                title: 'Delete ' + name + '?',
                text: "This action cannot be undone.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d4af37',
                cancelButtonColor: '#004225',
                confirmButtonText: 'Yes, Delete',
                background: '#081c15',
                color: '#ffffff'
            }).then((result) => {

                if (result.isConfirmed) {

                    const form = document.getElementById('delete-form-' + id);

                    if (form) {
                        form.submit();
                    }
                    else {
                        console.log("FORM NOT FOUND");
                    }
                }

            });
        }

    </script>

}