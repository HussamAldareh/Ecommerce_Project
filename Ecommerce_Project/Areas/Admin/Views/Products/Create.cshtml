@model Ecommerce_Project.Models.Product

@{
    Layout = "_AdminLayout";
    ViewData["PageTitle"] = "Add New Product";
    ViewData["PageCrumb"] = "Catalogue / Products / Create";
}

<div class="page-section active">
    <div class="page-header">
        <h5><i class="bi bi-plus-circle-fill me-2" style="color:var(--gold)"></i>Create Premium Product</h5>
        <a asp-area="Admin" asp-action="Index" class="btn-lx-outline"><i class="bi bi-arrow-left"></i> Back to List</a>
    </div>

    <form asp-area="Admin" asp-action="Create" method="post" enctype="multipart/form-data">
        <div class="row g-4">

            <div class="col-lg-8">
                <div class="lx-card">
                    <div class="lx-card-header">
                        <div class="lx-card-title">General Information</div>
                    </div>
                    <div class="lx-card-body">
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">Product Name</label>
                            <input asp-for="Name" class="form-control" placeholder="e.g., Rolex Datejust 41" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">Full Description</label>
                            <textarea asp-for="Description" class="form-control" rows="5" placeholder="Describe the luxury features..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Price" class="form-label">Price (JOD)</label>
                                <input asp-for="Price" class="form-control" type="number" step="0.01" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="StockQuantity" class="form-label">Stock Quantity</label>
                                <input asp-for="StockQuantity" class="form-control" type="number" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="lx-card mb-4">
                    <div class="lx-card-header"><div class="lx-card-title">Classification</div></div>
                    <div class="lx-card-body">
                        <div class="mb-3">
                            <label class="form-label">Category</label>
                            <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId">
                                <option value="">-- Select Category --</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="lx-card">
                    <div class="lx-card-header"><div class="lx-card-title">Product Media</div></div>
                    <div class="lx-card-body">
                        <div class="upload-zone" onclick="document.getElementById('file-input').click()" id="upload-zone">
                            <i class="bi bi-cloud-arrow-up-fill"></i>
                            <p>Upload Product Images</p>
                            <small>Select multiple files at once</small>

                            <input type="file" name="imageFiles" id="file-input" multiple class="d-none" onchange="previewImgs(event)" accept="image/*" />
                        </div>

                        <div id="img-preview" class="img-preview-grid mt-3"></div>
                    </div>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn-lx-primary w-100 py-3">
                        <i class="bi bi-check-lg me-2"></i>Publish Product
                    </button>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // Visual Preview Logic for Multiple Images
        function previewImgs(evt) {
            const grid = document.getElementById('img-preview');
            grid.innerHTML = '';

            const files = Array.from(evt.target.files);

            files.forEach(file => {
                if (!file.type.startsWith('image/')) return;

                const reader = new FileReader();
                reader.onload = e => {
                    const wrap = document.createElement('div');
                    wrap.className = 'img-prev-wrap';
                    wrap.innerHTML = `
                        <img src="${e.target.result}" class="img-prev"/>
                        <div class="img-prev-del" onclick="this.parentElement.remove()">
                            <i class="bi bi-x-lg"></i>
                        </div>`;
                    grid.appendChild(wrap);
                };
                reader.readAsDataURL(file);
            });
        }
    </script>
}