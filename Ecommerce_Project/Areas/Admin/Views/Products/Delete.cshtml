@model Ecommerce_Project.Models.Product
@{
    Layout = "_AdminLayout";
    ViewData["PageTitle"] = "Confirm Deletion";
}

<div class="page-section active">
    <div class="lx-card border-danger">
        <div class="lx-card-body text-center py-5">
            <div class="mb-4" style="font-size: 50px; color: var(--danger)">
                <i class="bi bi-exclamation-triangle"></i>
            </div>
            <h4>Are you sure you want to delete <strong>@Model.Name</strong>?</h4>
            <p class="text-muted">This action cannot be undone and will remove all associated images.</p>
            
            <form asp-area="Admin" asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn-lx-danger">Yes, Delete Product</button>
                <a asp-area="Admin" asp-action="Index" class="btn-lx-outline">Cancel</a>
            </form>
        </div>
    </div>
</div>