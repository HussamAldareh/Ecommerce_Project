@model IEnumerable<Ecommerce_Project.Models.Order>

@{
    Layout = "_AdminLayout";
    ViewData["PageTitle"] = "Orders";
}

<div class="row g-3 mb-4">
    <div class="col-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon icon-gold"><i class="bi bi-coin"></i></div>
            <div>
                <div class="stat-num">$@Model.Sum(o => o.TotalAmount).ToString("N0")</div>
                <div class="stat-lbl">Total Value</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon icon-green"><i class="bi bi-check-circle-fill"></i></div>
            <div>
                <div class="stat-num">@Model.Count(o => o.Status == "Completed")</div>
                <div class="stat-lbl">Completed</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon icon-blue"><i class="bi bi-arrow-repeat"></i></div>
            <div>
                <div class="stat-num">@Model.Count(o => o.Status == "Processing")</div>
                <div class="stat-lbl">Processing</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon icon-red"><i class="bi bi-x-circle-fill"></i></div>
            <div>
                <div class="stat-num">@Model.Count(o => o.Status == "Cancelled")</div>
                <div class="stat-lbl">Cancelled</div>
            </div>
        </div>
    </div>
</div>

@* Active user filter banner *@
@if (ViewData["FilterTitle"].ToString() != "All Orders Entries")
{
    <div class="user-filter-banner mb-3">
        <i class="bi bi-person-circle"></i>
        <span>Filtering by: <strong>@ViewData["FilterTitle"]</strong></span>
        <a asp-area="Admin" asp-action="Index" class="btn-lx-outline ms-auto">
            <i class="bi bi-x-lg"></i> Clear Filter
        </a>
    </div>
}

@* Main card *@
<div class="lx-card shadow-sm border-0">

    @* Card header *@
    <div class="lx-card-header">
        <div class="lx-card-title">
            <i class="bi bi-journal-text"></i>
            @ViewData["FilterTitle"]
        </div>
        <div class="d-flex gap-2 align-items-center flex-wrap">
            <select id="status-filter" class="form-select form-select-sm lx-input-mini"
                    onchange="filterByStatus(this.value)"
                    style="min-width:150px; height:34px;">
                <option value="">All Statuses</option>
                <option value="Processing">Processing</option>
                <option value="Completed">Completed</option>
                <option value="Cancelled">Cancelled</option>
            </select>
        </div>
    </div>

    @* Filter bar / search *@
    <div class="filter-bar">
        <div class="search-wrap">
            <i class="bi bi-search"></i>
            <input type="text"
                   id="order-search"
                   class="form-control"
                   placeholder="Search by ID, FullName, amount…"
                   oninput="filterTable()" />
        </div>
    </div>

    @* Table *@
    <div class="table-wrap">
        <table class="lx-table" id="orders-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Client Vault</th>
                    <th>Placement Date</th>
                    <th>Total Value</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr data-status="@item.Status"
                        data-search="@item.Id @item.User?.FullName @item.TotalAmount">
                        <td>
                            <span style="color:var(--muted);font-size:12px">#</span><strong>@item.Id</strong>
                        </td>
                        <td>
                            <a asp-area="Admin" asp-action="Index"
                               asp-route-userId="@item.UserId"
                               class="fw-bold text-decoration-none"
                               style="color:var(--gold)">
                                @item.User?.FullName
                            </a>
                        </td>
                        <td style="color:var(--muted);font-size:13px">
                            @item.OrderDate.ToString("MMM dd, yyyy")
                        </td>
                        <td style="color:#4ade80;font-weight:700">
                            $@item.TotalAmount.ToString("N2")
                        </td>
                        <td>
                            <span id="status-badge-@item.Id"
                                  class="lx-badge @(item.Status == "Completed" ? "b-success" : item.Status == "Cancelled" ? "b-danger" : "b-warning")">
                                @item.Status
                            </span>
                        </td>
                        <td>
                            <div class="d-flex gap-2 align-items-center">
                                <select class="form-select form-select-sm lx-input-mini"
                                        style="min-width:140px; height:30px; font-size:12px;"
                                        onchange="updateOrderStatus(@item.Id, this.value, this)"
                                        aria-label="Update status for order #@item.Id">
                                    <option value="" disabled selected>Update…</option>
                                    <option value="Processing">Processing</option>
                                    <option value="Completed">Completed</option>
                                    <option value="Cancelled">Cancelled</option>
                                </select>
                                <a asp-action="Details"
                                   asp-route-id="@item.Id"
                                   class="btn-icon view"
                                   title="View order #@item.Id">
                                    <i class="bi bi-eye-fill"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* Table footer — row count *@
    <div class="d-flex align-items-center justify-content-between px-4 py-2"
         style="background:var(--green-dark);border-top:1px solid var(--border);font-size:12px;color:var(--muted);">
        <span id="row-count">@Model.Count() entries</span>
    </div>
</div>

@* Toast notification *@
<div id="lx-toast-container" style="position:fixed;bottom:24px;right:24px;z-index:9999;display:flex;flex-direction:column;gap:8px;"></div>

@* Extra page-specific styles *@
