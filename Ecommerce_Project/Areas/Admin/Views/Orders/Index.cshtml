@* Page scripts *@
<script>
    /* ── Client-side status update ─────────────────────── */
    async function updateOrderStatus(orderId, newStatus, selectEl) {
        if (!newStatus) return;

        try {
            const res = await fetch(`/Orders/UpdateStatus`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('[name=__RequestVerificationToken]')?.value ?? ''
                },
                body: JSON.stringify({ id: orderId, status: newStatus })
            });

            if (!res.ok) throw new Error('Server error');

            /* Update badge in-place */
            const badge = document.getElementById('status-badge-' + orderId);
            if (badge) {
                badge.className = 'lx-badge ' + badgeClass(newStatus);
                badge.textContent = newStatus;

                /* Also update data-status on the row for the status filter */
                badge.closest('tr').dataset.status = newStatus;
            }

            showToast(`Order #${orderId} → ${newStatus}`, newStatus === 'Cancelled' ? 'danger' : newStatus === 'Processing' ? 'warning' : 'success');
        } catch (err) {
            showToast('Failed to update status', 'danger');
            console.error(err);
        } finally {
            selectEl.value = ''; /* Reset to placeholder */
        }
    }

    /* ── Badge class helper ────────────────────────────── */
    function badgeClass(status) {
        if (status === 'Completed') return 'b-success';
        if (status === 'Cancelled') return 'b-danger';
        return 'b-warning';
    }

    /* ── Client-side search filter ─────────────────────── */
    function filterTable() {
        applyFilters();
    }

    function filterByStatus(value) {
        applyFilters();
    }

    function applyFilters() {
        const q = document.getElementById('order-search').value.toLowerCase().trim();
        const status = document.getElementById('status-filter').value;
        const rows = document.querySelectorAll('#orders-table tbody tr');
        let visible = 0;

        rows.forEach(row => {
            const matchSearch = !q || row.dataset.search?.toLowerCase().includes(q);
            const matchStatus = !status || row.dataset.status === status;
            const show = matchSearch && matchStatus;
            row.classList.toggle('lx-hidden', !show);
            if (show) visible++;
        });

        const total = rows.length;
        document.getElementById('row-count').textContent =
            q || status
                ? `Showing ${visible} of ${total} entries`
                : `${total} entries`;
    }

    /* ── Toast ─────────────────────────────────────────── */
    function showToast(message, type = 'success') {
        const iconMap = { success: 'bi-check-circle-fill', danger: 'bi-x-circle-fill', warning: 'bi-arrow-repeat' };
        const bgMap   = { success: 'var(--success)', danger: 'var(--danger)', warning: 'var(--warning)' };
        const colorMap = { success: '#fff', danger: '#fff', warning: '#111' };

        const toast = document.createElement('div');
        toast.className = 'lx-toast';
        toast.style.cssText = `background:${bgMap[type]};color:${colorMap[type]};display:flex;align-items:center;gap:10px;padding:12px 18px;border-radius:11px;font-size:13px;font-weight:600;min-width:220px;box-shadow:0 8px 20px rgba(0,0,0,.4);animation:slideToast .3s ease;`;
        toast.innerHTML = `<i class="bi ${iconMap[type]}" style="font-size:17px;flex-shrink:0"></i><span>${message}</span>`;

        const container = document.getElementById('lx-toast-container');
        container.appendChild(toast);
        setTimeout(() => toast.remove(), 3500);
    }
</script>
