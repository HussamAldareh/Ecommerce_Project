@model IEnumerable<Ecommerce_Project.Models.ReviewItemViewModel>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Review Archive Trash Bin";
}

<div class="lx-card shadow-sm border-0">
    <div class="lx-card-header d-flex justify-content-between align-items-center">
        <div class="lx-card-title text-danger">
            <i class="bi bi-trash-fill"></i> Trashed Reviews Archive
        </div>
        <a asp-area="Admin" asp-controller="ProductComments" asp-action="Index" class="btn-lx-outline">
            <i class="bi bi-arrow-left"></i> Back to Active Queue
        </a>
    </div>

    <div class="table-wrap">
        <table class="lx-table">
            <thead>
                <tr>
                    <th>Customer</th>
                    <th>Product</th>
                    <th>Feedback Text</th>
                    <th style="text-align: right;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted p-4">The archive vault is completely empty.</td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr id="archive-row-@item.CommentId">
                        <td><strong>@item.CustomerName</strong></td>
                        <td style="color:var(--gold);">@item.ProductName</td>
                        <td class="text-white">"@item.CommentText"</td>
                        <td>
                            <div class="d-flex gap-2 justify-content-end">
                                @* Restore Trigger Button *@
                                <button type="button" class="btn-icon view" onclick="restoreCommentItem(@item.CommentId, this)" title="Restore to Active Vault">
                                    <i class="bi bi-arrow-counterclockwise" style="color:var(--success);"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        async function restoreCommentItem(id, element) {
            try {
                const response = await fetch(`/Admin/ProductComments/RestoreComment?id=${id}`, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? ''
                    }
                });

                if (!response.ok) throw new Error('Restoration failed');
                const data = await response.json();

                if (data.success) {
                    // Smoothly animate the row flying out of the trash view
                    const row = element.closest('tr');
                    row.style.transition = "all 0.4s ease";
                    row.style.opacity = "0";
                    row.style.transform = "translateY(-15px)";

                    setTimeout(() => row.remove(), 400);
                    notify('success', 'Archive Vault', 'Review successfully restored to live listings.');
                }
            } catch (error) {
                Swal.fire('Error', 'Could not restore this item.', 'error');
            }
        }
    </script>
}