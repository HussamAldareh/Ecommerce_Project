@model Ecommerce_Project.Models.Category
@{
    Layout = "_AdminLayout";
    ViewData["PageTitle"] = "Create Category";
}

<div class="page-section active">
    <div class="page-header">
        <h5><i class="bi bi-plus-circle-fill me-2" style="color:var(--gold)"></i>New Category</h5>
        <a asp-action="Index" class="btn-lx-outline">Back to List</a>
    </div>

    <div class="row">
        <div class="col-lg-6">
            <div class="lx-card">
                <div class="lx-card-body">
                    <form asp-area="Admin" asp-action="Create" enctype="multipart/form-data">
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">Category Name</label>
                            <input asp-for="Name" class="form-control" id="cat-name" oninput="generateSlug(this.value)" placeholder="e.g. Luxury Watches" />
                        </div>
                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">Category Description</label>
                            <textarea asp-for="Description" class="form-control" rows="3"
                                      placeholder="Briefly describe what this category contains..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label class="control-label fw-bold">Upload Category Image</label>
                            <input type="file" name="ImageFile" class="form-control" accept="image/*" />
                            <span class="small">Select a JPG or PNG file.</span>
                        </div>

                        <button type="submit" class="btn-lx-gold w-100">Create Category</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
