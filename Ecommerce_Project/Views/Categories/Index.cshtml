@model IEnumerable<Ecommerce_Project.Models.Category>

@{
    ViewData["Title"] = "Categories";
}

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-success">Categories</h2>

        <a asp-action="Create" class="btn btn-success">
            Create New
        </a>
    </div>

    <table class="table table-hover align-middle shadow-sm">

        <thead class="table-success">
            <tr>
                <th>Image</th>
                <th>Name</th>
                <th>Description</th>
                <th width="150">Actions</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>

                    <td>
                        <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/images/default-cat.png" : item.ImageUrl)"
                             style="width:60px; height:60px; border-radius:10px; object-fit:cover;" />
                    </td>

                    <td>
                        <strong>@item.Name</strong>
                    </td>

                    <td>
                        @item.Description
                    </td>

                    <td>

                        <div class="d-flex gap-2">

                            <a asp-action="Edit"
                               asp-route-id="@item.Id"
                               class="btn btn-warning btn-sm">
                                Edit
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.Id"
                               class="btn btn-danger btn-sm">
                                Delete
                            </a>

                        </div>

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>