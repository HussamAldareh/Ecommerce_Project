@model IEnumerable<Ecommerce_Project.Models.Product>
@using Ecommerce_Project.Models

@{
    ViewData["Title"] = "Home";

    var testimonials = ViewBag.Testimonials as List<Testimonial>;
}

<style>

    body {
        background: #081c15;
        color: white;
        font-family: 'Poppins', sans-serif;
    }

    a {
        text-decoration: none;
    }

    /* HERO */

    .hero-section {
        width: 100%;
        min-height: 100vh;
        padding: 0;
    }

    .hero-overlay {
        position: relative;
        width: 100%;
        height: 100vh;
        overflow: hidden;
    }

    .hero-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .hero-content {
        position: absolute;
        bottom: 80px;
        left: 50%;
        transform: translateX(-50%);
        text-align: center;
        width: 100%;
    }

    .hero-title {
        color: white;
        font-size: 55px;
        font-weight: 800;
        margin-bottom: 25px;
        text-shadow: 0 5px 20px rgba(0,0,0,0.6);
    }

    .hero-btn {
        background: #d4af37;
        color: #081c15;
        padding: 15px 45px;
        border-radius: 50px;
        font-weight: bold;
        transition: 0.3s;
        display: inline-block;
        font-size: 18px;
        width: 220px;
        border: none;
        box-shadow: 0 10px 25px rgba(0,0,0,0.3);
    }

        .hero-btn:hover {
            background: #004225;
            color: white;
            transform: translateY(-5px);
        }

    /* SECTION */

    .section-title {
        font-size: 50px;
        font-weight: bold;
        margin-bottom: 50px;
        text-align: center;
        color: #d4af37;
    }

    /* CATEGORY */

    .category-card {
        position: relative;
        overflow: hidden;
        border-radius: 25px;
        height: 420px;
        cursor: pointer;
        box-shadow: 0 10px 30px rgba(0,0,0,0.4);
        transition: 0.4s;
    }

        .category-card:hover {
            transform: translateY(-8px);
        }

        .category-card img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: 0.5s;
        }

        .category-card:hover img {
            transform: scale(1.1);
        }

    .category-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(8,28,21,0.95), rgba(8,28,21,0.15));
        display: flex;
        flex-direction: column;
        justify-content: end;
        padding: 35px;
    }

        .category-overlay h2 {
            font-size: 38px;
            font-weight: bold;
            color: #d4af37;
        }

    /* PRODUCT */

    .product-card {
        background: #10271f;
        border-radius: 20px;
        overflow: hidden;
        transition: 0.35s;
        border: 1px solid rgba(212,175,55,0.15);
        box-shadow: 0 5px 25px rgba(0,0,0,0.25);
        height: 100%;
    }

        .product-card:hover {
            transform: translateY(-10px) scale(1.02);
        }

        .product-card img {
            height: 240px;
            width: 100%;
            object-fit: cover;
        }

    .product-content {
        padding: 18px;
    }

    .product-name {
        font-size: 18px;
        font-weight: bold;
        color: white;
    }

    .product-description {
        color: #cfcfcf;
        min-height: 45px;
        font-size: 14px;
    }

    .product-price {
        color: #d4af37;
        font-size: 20px;
        font-weight: bold;
    }

    .view-btn {
        background: #d4af37;
        color: #081c15;
        border-radius: 50px;
        padding: 8px 18px;
        font-weight: bold;
        transition: 0.3s;
        border: none;
    }

        .view-btn:hover {
            background: #004225;
            color: white;
        }

    /* TESTIMONIALS */

    .testimonial-wrapper {
        position: relative;
        overflow: hidden;
    }

    .testimonial-slider {
        display: flex;
        gap: 20px;
        overflow-x: auto;
        scroll-behavior: smooth;
        padding-bottom: 10px;
    }

        .testimonial-slider::-webkit-scrollbar {
            display: none;
        }

    .testimonial-card {
        min-width: 350px;
        background: #10271f;
        border-radius: 20px;
        padding: 25px;
        border: 1px solid rgba(212,175,55,0.15);
        flex-shrink: 0;
    }

    .slider-btn {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        background: #d4af37;
        color: #081c15;
        border: none;
        width: 45px;
        height: 45px;
        border-radius: 50%;
        font-size: 22px;
        cursor: pointer;
        z-index: 10;
        transition: 0.3s;
    }

        .slider-btn:hover {
            background: white;
        }

    .prev-btn {
        left: -10px;
    }

    .next-btn {
        right: -10px;
    }

    textarea:focus {
        box-shadow: none !important;
        border-color: #d4af37 !important;
        background: #081c15 !important;
        color: white !important;
    }

    footer {
        margin-top: 120px;
        background: #04110d;
        padding: 70px 0;
    }

    @@media(max-width:768px) {

        .hero-title {
            font-size: 35px;
        }

        .section-title {
            font-size: 35px;
        }

        .testimonial-card {
            min-width: 280px;
        }

        .category-card {
            height: 320px;
        }
    }

</style>

<!-- HERO -->

<section class="hero-section">

    <div class="hero-overlay">

        <img src="/images/ChatGPT Image 18 مايو 2026، 01_32_05 م.png"
             class="hero-image" />

        <div class="hero-content">

            <a href="#products"
               class="hero-btn">
                SHOP NOW
            </a>

        </div>

    </div>

</section>

<!-- CATEGORIES -->

<section class="container mt-5">

    <h2 class="section-title">
        Featured Categories
    </h2>

    <div class="row g-4">

        <div class="col-md-6">

            <a asp-controller="Products"
               asp-action="ByCategory"
               asp-route-id="2">

                <div class="category-card">

                    <img src="/images/products/fd4ae1af-b484-4ffd-a395-46f9cc5e179e.jpeg" />

                    <div class="category-overlay">

                        <h2>Luxury Watch</h2>

                        <p>Crafted for luxury lifestyle</p>

                    </div>

                </div>

            </a>

        </div>

        <div class="col-md-6">

            <a asp-controller="Products"
               asp-action="ByCategory"
               asp-route-id="3">

                <div class="category-card">

                    <img src="/images/products/1963e7cc-88d6-4ed9-bbfa-ce2e7a962ad9.jpg" />

                    <div class="category-overlay">

                        <h2>Elegant Bags</h2>

                        <p>Explore premium collections</p>

                    </div>

                </div>

            </a>

        </div>

    </div>

</section>

<!-- OFFERS -->

<section class="container mt-5">

    <div class="col-md-12">

        <a asp-controller="Products"
           asp-action="Offers">

            <div class="category-card"
                 style="height:300px;">

                <img src="/images/Gemini_Generated_Image_emcby5emcby5emcb.png" />

                <div class="category-overlay">

                    <h2>Exclusive Offers</h2>

                    <p>Discover premium discounts</p>

                </div>

            </div>

        </a>

    </div>

</section>

<!-- PRODUCTS -->

<section class="container mt-5"
         id="products">

    <h2 class="section-title">
        New Arrivals
    </h2>

    <div class="row g-4">

        @foreach (var item in Model.Take(8))
        {
            var firstImage = item.ProductImages?.FirstOrDefault();

            <div class="col-lg-3 col-md-4 col-sm-6">

                <div class="product-card">

                    @if (firstImage != null)
                    {
                        <img src="@firstImage.ImageUrl" />
                    }
                    else
                    {
                        <img src="/images/no-image.png" />
                    }

                <div class="product-content">

                    <h5 class="product-name">
                        @item.Name
                    </h5>

                    <p class="product-description">

                        @(item.Description.Length > 60
                                                ? item.Description.Substring(0, 60) + "..."
                                                : item.Description)

                    </p>

                        <div class="d-flex justify-content-between align-items-center mt-3">

                            <span class="product-price">
                                @item.Price JD
                            </span>

                            <a asp-controller="Products"
                               asp-action="Details"
                               asp-route-id="@item.Id"
                               class="view-btn">
                                View
                            </a>

                        </div>

                    </div>

                </div>

            </div>
                }

    </div>

</section>

<!-- TESTIMONIALS -->
@if (testimonials != null && testimonials.Any())
{
    <section class="container mt-5">

        <h2 class="section-title">
            What Our Clients Say
        </h2>

        <div class="testimonial-wrapper">

            <button class="slider-btn prev-btn">
                ‹
            </button>

            <div class="testimonial-slider"
                 id="testimonialSlider">

                @foreach (var item in testimonials)
                {
                    <div class="testimonial-card">

                        <div class="d-flex align-items-center mb-3">

                            <div style="
                                        width:60px;
                                        height:60px;
                                        border-radius:50%;
                                        background:#d4af37;
                                        color:#081c15;
                                        display:flex;
                                        align-items:center;
                                        justify-content:center;
                                        font-size:24px;
                                        font-weight:bold;">

                                @item.User.UserName.Substring(0, 1).ToUpper()

                            </div>

                            <div class="ms-3">

                                <h5 class="mb-0 text-white fw-bold">
                                    @item.User.FullName
                                </h5>

                                <small class="text-warning">
                                    Verified Customer
                                </small>

                            </div>

                        </div>

                        <p class="text-light mb-0"
                           style="line-height:1.8;">

                            "@item.Message"

                        </p>

                    </div>
                }

            </div>

            <button class="slider-btn next-btn">
                ›
            </button>

        </div>

    </section>
}

<!-- ADD TESTIMONIAL -->
@if (User.Identity.IsAuthenticated)
{
    <section class="container mt-5 mb-5">

        <div class="product-card p-5">

            <h2 class="section-title mb-4">
                Share Your Experience
            </h2>

            <form asp-controller="Testimonials"
                  asp-action="Create"
                  method="post">

                <textarea name="Message"
                      class="form-control mb-4"
                      rows="5"
                      placeholder="Write your opinion about our website..."
                      style="
                              background:#081c15;
                              border:1px solid rgba(212,175,55,0.2);
                              color:white;
                              border-radius:20px;
                              padding:20px;"></textarea>

                <button type="submit"
                        class="view-btn">
                    Submit Review
                </button>

            </form>

        </div>

    </section>
}

<script>

    const slider = document.getElementById("testimonialSlider");

    const nextBtn = document.querySelector(".next-btn");
    const prevBtn = document.querySelector(".prev-btn");

    nextBtn.addEventListener("click", () => {

        slider.scrollBy({
            left: 370,
            behavior: "smooth"
        });

    });

    prevBtn.addEventListener("click", () => {

        slider.scrollBy({
            left: -370,
            behavior: "smooth"
        });

    });

    // AUTO SLIDE

    setInterval(() => {

        if (slider.scrollLeft + slider.clientWidth >= slider.scrollWidth - 10) {

            slider.scrollTo({
                left: 0,
                behavior: "smooth"
            });

        }
        else {

            slider.scrollBy({
                left: 370,
                behavior: "smooth"
            });

        }

    }, 4000);

</script>