@model Ecommerce_Project.Models.Product

@{
    ViewData["Title"] = "Product Details";

    var averageRating = Model.ProductRatings != null &&
                        Model.ProductRatings.Any()
        ? Model.ProductRatings.Average(r => r.RatingValue)
        : 0;

    var firstImage = Model.ProductImages?.FirstOrDefault();
}

<style>

    body {
        background: #081c15;
        color: white;
        font-family: 'Poppins', sans-serif;
    }

    .product-wrapper {
        padding-top: 70px;
        padding-bottom: 70px;
    }

    .product-image {
        width: 100%;
        height: 650px;
        object-fit: cover;
        border-radius: 30px;
        border: 1px solid rgba(212,175,55,0.15);
        box-shadow: 0 10px 40px rgba(0,0,0,0.4);
    }

    .thumbnail {
        width: 90px;
        height: 90px;
        object-fit: cover;
        border-radius: 15px;
        border: 2px solid rgba(212,175,55,0.2);
        transition: 0.3s;
    }

        .thumbnail:hover {
            transform: scale(1.08);
            border-color: #d4af37;
        }

    .category-badge {
        background: #d4af37;
        color: #081c15;
        padding: 10px 18px;
        border-radius: 50px;
        font-weight: bold;
        display: inline-block;
        margin-bottom: 20px;
    }

    .product-title {
        font-size: 60px;
        font-weight: bold;
    }

    .product-description {
        color: #cfcfcf;
        font-size: 18px;
        line-height: 1.8;
        margin-top: 20px;
    }

    .product-price {
        color: #d4af37;
        font-size: 42px;
        font-weight: bold;
        margin-top: 25px;
    }

    .rating-box {
        margin-top: 20px;
        font-size: 20px;
    }

    .action-btn {
        padding: 16px 40px;
        border-radius: 50px;
        border: none;
        font-weight: bold;
        transition: 0.3s;
        font-size: 18px;
        min-width: 220px;
    }

    .cart-btn {
        background: #d4af37;
        color: #081c15;
    }

        .cart-btn:hover {
            background: #004225;
            color: white;
        }

    .wishlist-btn {
        background: transparent;
        border: 2px solid #d4af37;
        color: #d4af37;
    }

        .wishlist-btn:hover {
            background: #d4af37;
            color: #081c15;
        }

    .stock-box {
        margin-top: 25px;
    }

    .stock-in {
        background: #198754;
        padding: 10px 18px;
        border-radius: 50px;
    }

    .stock-out {
        background: #dc3545;
        padding: 10px 18px;
        border-radius: 50px;
    }

    .glass-card {
        background: #10271f;
        border-radius: 25px;
        padding: 35px;
        border: 1px solid rgba(212,175,55,0.15);
        box-shadow: 0 10px 30px rgba(0,0,0,0.25);
    }

    .section-title {
        color: #d4af37;
        font-size: 34px;
        font-weight: bold;
        margin-bottom: 25px;
    }

    .comment-box {
        background: #0f221c;
        border-radius: 20px;
        padding: 25px;
        margin-bottom: 20px;
        border: 1px solid rgba(212,175,55,0.1);
    }

    textarea,
    select,
    .form-control,
    .form-select {
        background: #081c15 !important;
        border: 1px solid rgba(212,175,55,0.2) !important;
        color: white !important;
        border-radius: 15px !important;
    }

        textarea::placeholder {
            color: #ccc !important;
        }

    .submit-btn {
        background: #d4af37;
        color: #081c15;
        border: none;
        border-radius: 50px;
        padding: 12px 30px;
        font-weight: bold;
    }

        .submit-btn:hover {
            background: #004225;
            color: white;
        }



    .btn-warning {  
        background: #d4af37;
        border: none;
        color: #081c15;
    }

        .btn-warning:hover {
            background: #b8962e;
            color: white;
        }

    .btn-outline-light:hover {
        background: #d4af37;
        border-color: #d4af37;
        color: #081c15;
    }



</style>

<div class="container product-wrapper">

    <div class="row g-5 align-items-center">

        <!-- IMAGE -->

        <div class="col-lg-6">

            @if (firstImage != null)
            {
                <img src="@firstImage.ImageUrl"
                     class="product-image mb-4" />
            }
            else
            {
                <img src="/images/no-image.png"
                     class="product-image mb-4" />
            }

            <div class="d-flex gap-3 flex-wrap">

                @foreach (var img in Model.ProductImages)
                {
                    <img src="@img.ImageUrl"
                         class="thumbnail" />
                }

            </div>

        </div>

        <!-- DETAILS -->

        <div class="col-lg-6">

            <span class="category-badge">
                @Model.Category?.Name
            </span>

            <h1 class="product-title">
                @Model.Name
            </h1>

            <p class="product-description">
                @Model.Description
            </p>

            <div class="rating-box">
                ⭐ @averageRating.ToString("0.0") / 5
            </div>

            <div class="product-price">
                @Model.Price JD
            </div>

            <div class="d-flex gap-1 mt-4 flex-wrap">

                <form asp-controller="CartItems"
                      asp-action="AddToCart"
                      method="post">

                    <input type="hidden"
                           name="productId"
                           value="@Model.Id" />

                    <button type="submit"
                            class="action-btn cart-btn">
                        Add To Cart
                    </button>

                </form>

                <form asp-controller="Wishlists"
                      asp-action="AddToWishlist"
                      method="post">

                    <input type="hidden"
                           name="productId"
                           value="@Model.Id" />

                    <button type="submit"
                            class="btn btn-outline-light btn-lg rounded-pill px-4">
                        ♡ Wishlist
                    </button>

                </form>



            </div>

            <div class="stock-box">

                @if (Model.IsAvailable)
                {
                    <span class="stock-in">
                        In Stock
                    </span>
                }
                else
                {
                    <span class="stock-out">
                        Out Of Stock
                    </span>
                }

            </div>

        </div>

    </div>

    <!-- RATE -->

    <div class="glass-card mt-5">

        <h2 class="section-title">
            Rate Product
        </h2>

        <form asp-controller="ProductRatings"
              asp-action="Create"
              method="post">

            <input type="hidden"
                   name="productId"
                   value="@Model.Id" />

            <div class="d-flex gap-3">

                <select name="ratingValue"
                        class="form-select">

                    <option value="1">1 ⭐</option>
                    <option value="2">2 ⭐⭐</option>
                    <option value="3">3 ⭐⭐⭐</option>
                    <option value="4">4 ⭐⭐⭐⭐</option>
                    <option value="5">5 ⭐⭐⭐⭐⭐</option>

                </select>

                <button type="submit"
                        class="submit-btn">
                    Submit
                </button>

            </div>

        </form>

    </div>

    <!-- COMMENTS -->

    <div class="glass-card mt-5">

        <h2 class="section-title">
            Customer Reviews
        </h2>

        <form asp-controller="ProductComments"
              asp-action="Create"
              method="post"
              class="mb-5">

            <input type="hidden"
                   name="productId"
                   value="@Model.Id" />

            <textarea name="comment"
                      rows="5"
                      class="form-control mb-3"
                      placeholder="Write your opinion..."></textarea>

            <button type="submit"
                    class="submit-btn">
                Add Comment
            </button>

        </form>

        @if (Model.ProductComments != null &&
                Model.ProductComments.Any())
        {
            foreach (var item in Model.ProductComments)
            {
                <div class="comment-box">

                    <div class="d-flex justify-content-between mb-2">

                        <strong>
                            @item.User?.UserName
                        </strong>

                        <small class="text-light">
                            @item.CreatedAt.ToShortDateString()
                        </small>

                    </div>

                    <p class="mb-0 text-light">
                        @item.Comment
                    </p>

                </div>
            }
        }
        else
        {
            <div class="alert alert-dark">
                No reviews yet.
            </div>
        }

    </div>

</div>