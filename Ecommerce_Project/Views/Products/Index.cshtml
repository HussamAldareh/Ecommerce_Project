@model IEnumerable<Ecommerce_Project.Models.Product>

@{
    ViewData["Title"] = "Products";
}

<style>

    body {
        background: #081c15;
        color: white;
        font-family: 'Poppins', sans-serif;
    }

    .page-title {
        font-size: 60px;
        font-weight: bold;
        color: #d4af37;
    }

    .page-subtitle {
        color: #cfcfcf;
        margin-top: 10px;
        font-size: 18px;
    }

    .top-section {
        padding-top: 70px;
        padding-bottom: 40px;
    }

    /* SEARCH */

    .search-wrapper {
        background: #10271f;
        border: 1px solid rgba(212,175,55,0.15);
        border-radius: 24px;
        padding: 22px;
        margin-bottom: 40px;
        box-shadow: 0 5px 25px rgba(0,0,0,0.2);
    }

    .search-input {
        background: #081c15 !important;
        border: 1px solid rgba(212,175,55,0.18) !important;
        color: white !important;
        border-radius: 50px !important;
        padding: 14px 20px !important;
        transition: 0.3s;
    }

        .search-input::placeholder {
            color: #bfbfbf;
        }

        .search-input:focus {
            border-color: #d4af37 !important;
            box-shadow: 0 0 12px rgba(212,175,55,0.35) !important;
        }

    .search-btn {
        background: #d4af37;
        color: #081c15;
        border: none;
        border-radius: 50px;
        font-weight: bold;
        padding: 14px 25px;
        transition: 0.3s;
        width: 100%;
    }

        .search-btn:hover {
            background: #004225;
            color: white;
        }

    /* PRODUCT CARD */

    .product-card {
        background: #10271f;
        border-radius: 24px;
        overflow: hidden;
        transition: 0.35s;
        border: 1px solid rgba(212,175,55,0.15);
        height: 100%;
        box-shadow: 0 5px 25px rgba(0,0,0,0.25);
    }

        .product-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 35px rgba(212,175,55,0.18);
        }

    .product-image-wrapper {
        position: relative;
    }

        .product-image-wrapper img {
            height: 320px;
            width: 100%;
            object-fit: cover;
        }

    .discount-badge {
        position: absolute;
        top: 18px;
        left: 18px;
        background: linear-gradient(135deg, #ff3c3c, #b30000);
        color: white;
        padding: 10px 16px;
        border-radius: 50px;
        font-size: 14px;
        font-weight: bold;
        box-shadow: 0 5px 15px rgba(255,0,0,0.35);
        z-index: 10;
    }

    .product-content {
        padding: 24px;
    }

    .product-name {
        font-size: 24px;
        font-weight: bold;
        color: white;
    }

    .product-description {
        color: #cfcfcf;
        margin-top: 10px;
        min-height: 50px;
    }

    .old-price {
        text-decoration: line-through;
        color: #8f8f8f;
        font-size: 15px;
    }

    .new-price {
        color: #d4af37;
        font-size: 30px;
        font-weight: bold;
    }

    .product-price {
        color: #d4af37;
        font-size: 28px;
        font-weight: bold;
    }

    .view-btn {
        background: #d4af37;
        color: #081c15;
        border-radius: 50px;
        padding: 10px 24px;
        font-weight: bold;
        transition: 0.3s;
        border: none;
        text-decoration: none;
    }

        .view-btn:hover {
            background: #004225;
            color: white;
        }

</style>

<div class="container mt-5">

    <form method="get" class="search-wrapper">

        <div class="row g-3 align-items-center">

            <div class="col-lg-5">

                <input type="text"
                       name="search"
                       class="form-control search-input"
                       placeholder="🔍 Search luxury products..." />

            </div>

            <div class="col-lg-3">

                <input type="number"
                       step="0.01"
                       name="minPrice"
                       class="form-control search-input"
                       placeholder="Min Price" />

            </div>

            <div class="col-lg-2">

                <input type="number"
                       step="0.01"
                       name="maxPrice"
                       class="form-control search-input"
                       placeholder="Max Price" />

            </div>

            <div class="col-lg-2">

                <button type="submit"
                        class="search-btn">
                    Search
                </button>

            </div>

        </div>

    </form>

</div>

<div class="container top-section">

    <div class="text-center mb-5">

        <h1 class="page-title">
            Luxury Collection
        </h1>

        <p class="page-subtitle">
            Explore premium watches and handbags crafted for elegance.
        </p>

    </div>

    <div class="row g-4">

        @foreach (var item in Model)
        {
            var image = item.ProductImages?.FirstOrDefault();

            var activeDiscount = item.Discounts?
            .FirstOrDefault(d =>
            d.IsActive &&
            d.StartDate <= DateTime.Now &&
            d.EndDate >= DateTime.Now);

            decimal finalPrice = item.Price;

            if (activeDiscount != null)
            {
                finalPrice = item.Price -
                (item.Price * activeDiscount.Percentage / 100);
            }

            <div class="col-lg-3 col-md-4 col-sm-6">

                <div class="product-card">

                    <div class="product-image-wrapper">

                        @if (activeDiscount != null)
                        {
                            <span class="discount-badge">
                                -@activeDiscount.Percentage%
                            </span>
                        }

                        @if (image != null)
                        {
                            <img src="@image.ImageUrl" />
                        }
                        else
                        {
                            <img src="/images/no-image.png" />
                        }

                </div>

                <div class="product-content">

                    <h5 class="product-name">
                        @item.Name
                    </h5>

                    <p class="product-description">

                        @(item.Description.Length > 60
                                                ? item.Description.Substring(0, 60) + "..."
                                                : item.Description)

                    </p>

                        <div class="d-flex justify-content-between align-items-center mt-4">

                            <div>

                            @if (activeDiscount != null)
                                {
                                    <div class="d-flex flex-column">

                                        <span class="old-price">
                                            @item.Price JD
                                        </span>

                                        <span class="new-price">
                                            @finalPrice.ToString("0.00") JD
                                        </span>

                                    </div>
                                }
                                else
                                {
                                    <span class="product-price">
                                        @item.Price JD
                                    </span>
                                }

                            </div>

                            <a asp-action="Details"
                               asp-route-id="@item.Id"
                               class="view-btn">
                                View
                            </a>

                        </div>

                    </div>

                </div>

            </div>
        }

    </div>

</div>