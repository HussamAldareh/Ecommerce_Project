@model Ecommerce_Project.Models.Order

@{
    ViewData["Title"] = "Payment";
}

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card border-0 shadow-lg rounded-5 overflow-hidden">

                <!-- Top Section -->
                <div class="bg-dark text-white p-5 text-center">

                    <h1 class="fw-bold mb-3">
                        Secure Payment
                    </h1>

                    <p class="mb-0 text-light">
                        Complete your order safely and securely
                    </p>

                </div>

                <!-- Body -->
                <div class="card-body p-5">

                    <div class="row mb-5">

                        <div class="col-md-6 mb-4 mb-md-0">

                            <div class="border rounded-4 p-4 h-100">

                                <p class="text-muted mb-2">
                                    Order Number
                                </p>

                                <h4 class="fw-bold">
                                    #@Model.Id
                                </h4>

                            </div>

                        </div>

                        <div class="col-md-6">

                            <div class="border rounded-4 p-4 h-100 bg-light">

                                <p class="text-muted mb-2">
                                    Total Amount
                                </p>

                                <h2 class="fw-bold text-success mb-0">
                                    @Model.TotalAmount JD
                                </h2>

                            </div>

                        </div>

                    </div>

                    <!-- Fake Card UI -->
                    <div class="bg-dark text-white rounded-5 p-4 mb-5 shadow">

                        <div class="d-flex justify-content-between align-items-center mb-5">

                            <h5 class="fw-bold mb-0">
                                VISA
                            </h5>

                            <span class="badge bg-success px-3 py-2">
                                Secure
                            </span>

                        </div>

                        <h3 class="fw-light tracking-wide mb-4">
                            **** **** **** 2026
                        </h3>

                        <div class="d-flex justify-content-between">

                            <div>
                                <small class="text-light">
                                    Card Holder
                                </small>

                                <p class="mb-0 fw-bold">
                                    Hussam Aldareh
                                </p>
                            </div>

                            <div>
                                <small class="text-light">
                                    Expires
                                </small>

                                <p class="mb-0 fw-bold">
                                    12/29
                                </p>
                            </div>

                        </div>

                    </div>

                    <!-- Payment Button -->
                    <form asp-action="ConfirmPayment"
                          method="post">

                        <input type="hidden"
                               name="orderId"
                               value="@Model.Id" />

                        <button type="submit"
                                class="btn btn-dark btn-lg w-100 rounded-pill py-3 fw-bold">
                            Confirm Payment
                        </button>

                    </form>

                    <div class="text-center mt-4">

                        <small class="text-muted">
                            Protected checkout • SSL secured
                        </small>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>